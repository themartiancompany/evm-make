_bin="$(
  dirname \
    "$(
      command \
        -v \
        "env")")"
_lib="${_bin}/../lib"
source \
  "${_lib}/libcrash-bash/crash-bash"

# shellcheck disable=SC2034
_global_variables() {
  make_date=""
  target_command=""
  project_dir=""
  contracts_dir=""
  work_dir=""
  compiler_backend=""
  lib_dir=""
  cache_clean=""
  rebuild_skip=""
  target_languages=()
  target_languages_amount=""
  command_args=()
  color=""
  quiet=""
}

_requirements() {
  _check_cmd \
    'solidity-compiler'
}

_get_conf_dir_path() {
  local \
    _dir
  _dir="${HOME}/.config/evm-make"
  echo \
    "${_dir}"
}

_work_dir_auto_detect() {
  local \
    _dir
  _dir="${HOME}/.cache/evm-make"
  echo \
    "${_dir}"
}

_versions_get() {
  local \
    _contract_dirs=() \
    _dir \
    _dir_basename \
    _re
  _contract_dirs+=(
    "$@"
  )
  _re='^[0-9][0-9.]*$'
  for _dir in "${_contract_dirs[@]}"; do
    _dir_basename="$(
      basename \
        "${_dir}")"
    if [[ ${_dir_basename} =~ ${_re} ]] ; then
      _contract_versions+=(
        "${_dir_basename}"
      )
    fi
  done
}

_contract_setup() {
  local \
    _contracts_dir="${1}" \
    _target_contract="${2}" \
    _network \
    _item
  _sol="${_target_contract}.sol"
  _abi="${_target_contract}.abi.json"
  _bytecode="${_target_contract}.bin"
  _json="${_target_contract}.json"
  _contract_dir="${_project_dir}/${_contracts_dir}/${_target_contract}"
  _contract_deployments_dir="${_contract_dir}/deployments"
  if [[ -d "${_contract_deployments_dir}" ]]; then
    _msg=(
      "Contract dir: '${_contract_dir}'."
    )
    _msg_info \
      "${_msg[*]}"
    _msg=(
      "Deployments dir: '${_contract_deployments_dir}'."
    )
    _msg_info \
      "${_msg[*]}"
    _contract_dirs=(
      "${_contract_dir}/"*
    )
    _msg_info \
      "Found contract directories: '${_contract_dirs[*]}'."
    _versions_get \
      "${_contract_dirs[@]}"
    _msg_info \
      "Found versions: ${_contract_versions[*]}"
    for _item in "${_contract_deployments_dir}/"*; do
      if [[ -d "${_item}" ]]; then
        _contract_deployed_networks_config_dirs=(
          "${_item}"
        )
      fi;
    done
  fi
  for _network \
    in "${_contract_deployed_networks_config_dirs[@]}"; do
    _contract_deployed_networks+=(
      "$(basename \
           "${_network}")"
    )
  done
  _msg=(
    "Found contract '${_target_contract}'"
    "deployments configuration"
    "for networks '${_contract_deployed_networks[*]}'."
  )
  _msg_info \
    "${_msg[*]}"
}

_contract_build() {
  local \
    _contracts_dir="${1}" \
    _target_contract="${2}" \
    _compiler_backend="${3}" \
    _work_dir="${4}" \
    _cache_clean="${5}" \
    _rebuild_skip="${6}" \
    _compiler_opts=() \
    _contract_dirs=() \
    _contract_versions=() \
    _contract_deployed_networks=() \
    _build \
    _build_dir \
    _compiler_work_dir \
    _config_file \
    _deployment \
    _deployment_dir \
    _path_project_json \
    _path_project_sol \
    _network \
    _version \
    _msg=()
  _msg=(
    "Building contract '${_target_contract}'."
  )
  _msg_info \
    "${_msg[*]}"
  _contract_setup \
    "${_contracts_dir}" \
    "${_target_contract}"
  for _network in "${_contract_deployed_networks[@]}"; do
    _deployment_dir="${_contract_deployments_dir}/${_network}"
    if [[ -d "${_deployment_dir}" ]]; then
      _config_file="${_deployment_dir}/config.sh"
      source \
        "${_config_file}"
      for _version in "${!contract_address[@]}"; do
        _deployment="${_network}/${_version}"
        _build_dir="${_work_dir}/${_deployment}"
        _compiler_work_dir="${_build_dir}/build"
        _compiler_opts=()
        if [[ "${quiet}" == "n" ]]; then
          _compiler_opts+=(
            -v
          )
        fi
        if [[ "${_cache_clean}" == "y" ]]; then
          _compiler_opts+=(
            -l
          )
        fi
        _compiler_opts+=(
          -b
            "${_compiler_backend}"
          -C
            "${solc_version["${_version}"]}"
          -e
            "${evm_version["${_version}"]}"
          -w
            "${_compiler_work_dir}"
          -o
            "${_build_dir}"
        )
        mkdir \
          -p \
          "${_compiler_work_dir}"
        _build="true"
        if [[ "${_rebuild_skip}" == "y" ]]; then
          if [[ "${_compiler_backend}" == "solc" ]]; then
            if [[ -e "${_build_dir}/${_abi}" ]] && \
               [[ -e "${_build_dir}/${_bytecode}" ]]; then \
             _build="false"
            fi
          elif [[ "${_compiler_backend}" == "hardhat" ]]; then
            _path_build_json="${_build_dir}/contracts/${_sol}/${_json}"
            _msg=(
              "Looking for '${_path_build_json}'"
            )
            _msg_info \
              "${_msg[*]}"
            if [[ -e "${_path_build_json}" ]]; then
              _build="false"
            fi
          fi
        fi
        if [[ "${_build}" == "true" ]]; then
          _path_project_sol="$(
            realpath \
              "${_contract_dir}/${_version}/${_sol}")"
          _msg=(
            "Building '${_path_project_sol}'."
            "Running 'solidity-compiler' with"
            "options '${_compiler_opts[*]}'."
          )
          _msg_info \
            "${_msg[*]}"
          echo "mammt"
          solidity-compiler \
            "${_compiler_opts[@]}" \
            "${_path_project_sol}"
        elif [[ "${_build}" == "false" ]]; then
          _msg=(
            "Skipping build of '${_path_project_sol}'."
          )
          _msg_info \
            "${_msg[*]}"
        fi
      done
      _contract_built="true"
    else
      _msg=(
        "No deployments for"
        "contract '${_target_contract}'."
      )
      _msg_info \
        "${_msg[*]}"
    fi || \
    true
  done || \
  true
  true
}

_contract_install_common() {
  local \
    _install_opts=()
  if [[ "${quiet}" == "n" ]]; then
    _install_opts+=(
      -v
    )
  fi
  _install_opts+=(
    -dm755
  )
  install \
    "${_install_opts[@]}" \
    "${_lib_dir}"
}

_contract_install_sources() {
  local \
    _contracts_dir="${1}" \
    _target_contract="${2}" \
    _lib_dir="${3}" \
    _contract_dirs=() \
    _contract_versions=() \
    _contract_deployed_networks=() \
    _install_dir \
    _install_opts=() \
    _version
  if [[ "${quiet}" == "n" ]]; then
    _install_opts+=(
      -v
    )
  fi
  _install_opts+=(
    -Dm644
  )
  _contract_install_common
  _contract_setup \
    "${_contracts_dir}" \
    "${_target_contract}"
  _msg_info \
    "Installing sources for '${_target_contract}'"
  for _version in "${_contract_versions[@]}"; do \
    _install_dir="${_lib_dir}/contracts"
    install \
      "${_install_opts[@]}" \
      "${_contract_dir}/${_version}/${_sol}" \
      "${_install_dir}/${_target_contract}/${_version}/${_sol}"
  done
}

_contract_install_deployments_config() {
  local \
    _contracts_dir="${1}" \
    _target_contract="${2}" \
    _lib_dir="${3}" \
    _contract_dirs=() \
    _contract_versions=() \
    _contract_deployed_networks=() \
    _libevm_config_convert_opts=() \
    _msg=() \
    _install_dir \
    _network
  if [[ "${quiet}" == "n" ]]; then
    _libevm_config_convert_opts+=(
      -v
    )
  fi
  _msg=(
    "Installing deployments configurations"
    "for '${_target_contract}'"
  )
  _msg_info \
    "${_msg[*]}"
  _contract_install_common
  _contract_setup \
    "${_contracts_dir}" \
    "${_target_contract}"
  for _network in ${_contract_deployed_networks[@]}; do
    _deployment_dir="${_contract_deployments_dir}/${_network}"
    if [[ -d "${_deployment_dir}" ]]; then
      _config_file="${_deployment_dir}/config.sh"
      _install_dir="${_lib_dir}/deployments/${_target_contract}/${_network}"
      install \
        -Dm644 \
        "${_config_file}" \
        "${_install_dir}/config.sh"
      if [[ " ${target_languages[*]} " == *" javascript "* ]]; then
        libevm-config-convert \
          "${_libevm_config_convert_opts[@]}" \
          "${_config_file}" \
          "${_install_dir}/config.json"
      fi
    fi
  done
}

