_contracts_get() {
  local \
    _contracts_dir="${1}" \
    _contract \
    _contract_name \
    _contracts_dirs=() \
    _msg=()
  _contracts_dirs+=(
    "${_contracts_dir}/"*
  )
  for _contract_dir in "${_contracts_dirs[@]}"; do
    if [[ -d "${_contract_dir}" ]]; then
      _contract_name="$(
        basename \
          "${_contract_dir}")"
      for _path in "${_contract_dir}/"*"/${_contract_name}.sol"; do
        if [[ -e "${_path}" ]]; then
          _contracts+=(
            "${_contract_name}"
          )
          break
        else
          true
          # _msg=(
          #   "Directory '${_contract_dir}'"
          #   "is not a contract directory"
          #   "because '${_path}'"
          #   "does not exist."
          # )
          # _msg_info \
          #   "${_msg[*]}"
        fi
      done
    fi
  done
  _msg=(
    "Found contracts '${_contracts[*]}'."
  )
  _msg_info \
    "${_msg[*]}"
}

_evm_make() {
  local \
    _target_command="${1}" \
    _project_dir="${2}" \
    _contracts_dir="${3}" \
    _work_dir="${4}" \
    _compiler_backend="${5}" \
    _lib_dir="${6}" \
    _cache_clean="${7}" \
    _rebuild_skip="${8}" \
    _target_languages_amount="${9}" \
    _target_languages=() \
    _target_actions=() \
    _oldpwd \
    _contract \
    _contract_deployments_dir \
    _contracts=() \
    _contract_built \
    _contracts_dir \
    _sol \
    _abi \
    _bytecode \
    _json \
    _msg=() \
    _command_args=()
  shift \
    9
  for _index \
    in $(seq \
           "$(( "${_target_languages_amount}" -1 ))"); do
    _target_languages+=(
      "${1}"
    )
    shift
  done
  _command_args+=(
    "$@"
  )
  if [[ "${_contracts_dir}" == "" ]]; then
    _contracts_dir="contracts"
  fi
  _oldpwd="${PWD}"
  if [[ "${_target_command}" == "install" ]]; then
    _target_actions+=(
      "install_sources"
      "install_deployments_config"
      "install_deployments"
    )
  elif [[ "${_target_command}" == \
            "build" || \
          "${_target_command}" == \
            "install_sources" || \
          "${_target_command}" == \
            "install_deployments_config" || \
          "${_target_command}" == \
            "install_deployments" ]]; then
    _target_actions+=(
      "${_target_command}"
    )
  fi
  cd \
    "${_project_dir}"
  _contracts_get \
    "${_contracts_dir}"
  for _contract in "${_contracts[@]}"; do
    if [[ " ${_target_actions[*]} " == \
            *" build "* ]]; then
      _contract_build \
        "${_contracts_dir}" \
        "${_contract}" \
        "${_compiler_backend}" \
        "${_work_dir}" \
        "${_cache_clean}" \
        "${_rebuild_skip}" || \
      true
    fi
    if [[ " ${_target_actions[*]} " == \
            *" install_sources "* ]]; then
      _contract_install_sources \
        "${_contracts_dir}" \
        "${_contract}" \
        "${_lib_dir}"
    fi
    if [[ " ${_target_actions[*]} " == \
            *" install_deployments_config "* ]]; then
      _contract_install_deployments_config \
        "${_contracts_dir}" \
        "${_contract}" \
        "${_lib_dir}"
    fi
    if [[ " ${_target_actions[*]} " == \
            *" install_deployments "* ]]; then
      "_contract_install_deployments_${_compiler_backend}" \
        "${_contracts_dir}" \
        "${_contract}" \
        "${_lib_dir}" \
        "${_work_dir}" || \
      true
    fi
  done
  cd \
    "${_oldpwd}"
}

_cache_clean_auto_detect() {
  local \
    _clean \
    _backend
  _backend="${compiler_backend}"
  if [[ "${_backend}" == "hardhat" ]]; then
    _clean="y"
  elif [[ "${_backend}" == "solc" ]]; then
    _clean="n"
  fi
  _set_override \
    "cache" \
    "clean" \
    "${_clean}"
}

_project_dir_check() {
  local \
    _msg=() \
    _realpath
  if [[ ! -e "${project_dir}" ]]; then
    _msg+=(
      "Project directory"
      "'${project_dir}'"
      "does not exist."
    )
    _msg_error \
      "${_msg[*]}" \
      1
  fi
  _realpath="$(
    realpath \
      "${project_dir}")"
  if [[ -e "${_realpath}" ]]; then
    project_dir="${_realpath}"
  fi
}

_contracts_dir_auto_detect() {
  local \
    _contracts_dir
  _contracts_dir="contracts"
  if [[ ! -d "${project_dir}/${_contracts_dir}" ]]; then
    _contracts_dir="${project_dir}"
  fi
  _set_override \
    "contracts" \
    "dir" \
    "${_contracts_dir}"
}

_set_overrides() {
  if [[ -v override_quiet ]]; then
    quiet="${override_quiet}"
  elif [[ -z "${quiet}" ]]; then
    quiet="y"
  fi
  if [[ -v override_color ]]; then
    color="${override_color}"
  elif [[ -z "${color}" ]]; then
    color="n"
  fi
  if [[ "${target_languages[*]}" == "" ]]; then
    target_languages=(
      "bash"
      "javascript"
    )
  fi
  target_languages_amount="${#target_languages[@]}"
  _set_override \
    "make" \
    "date" \
    "$(_get_date_human)"
  _set_override \
    "project" \
    "dir" \
    "$(realpath \
         "${PWD}")"
  _project_dir_check
  _set_override \
    "work" \
    "dir" \
    "$(_work_dir_auto_detect)"
  _set_override \
    "lib" \
    "dir" \
    "${PWD}/build"
  _set_override \
    "rebuild" \
    "skip" \
    "n"
  _set_override \
    "compiler" \
    "backend" \
    "solc"
  _cache_clean_auto_detect
  _contracts_dir_auto_detect
}

# Show help usage, with an exit status.
# $1: exit status number.
_usage() {
  local \
    _exit="${1}"
  IFS='' \
    read \
      -r \
      -d '' \
      _usage_text << \
        ENDUSAGETEXT || true

EVM toolchain build and install tool.

Usage:

  ${app_name}
    [options]
    <command>

  commands:

    build
    install
    install_sources
    install_deployments_config
    install_deployments
    Default: ${target_command}

  options:

     -C <project-dir>       Project directory.
                            Default: ${project_dir}

     -p <contracts-dir>     Contracts directory inside
                            the project.
                            Default: ${contracts_dir}

     -b <compiler-backend>  Backend for solidity-compiler;
                            can be 'solc' or 'hardhat'.
                            Default: ${compiler_backend}

     -w <work-dir>          Work directory.
                            Default: ${work_dir}

     -o <lib-dir>           Install directory.
                            Default: ${lib_dir}

     -l <y/n>               Whether to pass the clean cache
                            option to solidity-compiler.
                            When the backend is 'hardhat'
                            defaults to 'y', while for 'solc' is 'n'.
                            Default: ${cache_clean}

     -L <language>          Target languages for the configuration file.
                            It can be 'bash' or 'javascript'.
                            Default: ${target_languages[@]}

     -f <y/n>               If 'y', skip rebuilding the contracts
                            if artifacts are found already in the
                            directory.

     -h                     This message.
     -c                     Enable color output
     -v                     Enable verbose output
ENDUSAGETEXT
  _printf \
    '%s\n' \
    "${_usage_text}"
  exit \
    "${_exit}"
}

# Shows configuration options.
_show_config() {
  _msg_info "${app_name} configuration"
  _msg_info "                Make date:   ${make_date}"
  _msg_info "           Target command:   ${target_command}"
  _msg_info "        Project directory:   ${project_dir}"
  _msg_info "      Contracts directory:   ${contracts_dir}"
  _msg_info "           Work directory:   ${work_dir}"
  _msg_info "        Install directory:   ${lib_dir}"
  _msg_info "         Compiler backend:   ${compiler_backend}"
  _msg_info "              Cache clean:   ${cache_clean}"
  _msg_info "             Skip rebuild:   ${rebuild_skip}"
  _msg_info "         Target languages:   ${rebuild_skip}"
}

_globals
_global_variables
_requirements
# shellcheck disable=SC2034
while \
  getopts \
    'C:p:w:o:b:l:L:f:cvh?' \
    arg; do
  case \
    "${arg}" in
    C)
      override_project_dir="${OPTARG}" ;;
    p)
      override_contracts_dir="${OPTARG}" ;;
    w)
      override_work_dir="$(
        realpath \
          "${OPTARG}")" ;;
    o)
      override_lib_dir="${OPTARG}" ;;
    b)
      override_compiler_backend="${OPTARG}" ;;
    l)
      override_cache_clean="${OPTARG}" ;;
    L)
      target_languages+=(
        "${OPTARG}"
      ) ;;
    f)
      override_rebuild_skip="${OPTARG}" ;;
    c)
      override_color="y" ;;
    v)
      override_quiet="n" ;;
    h|?)
      _set_overrides
      _usage \
        0 ;;
    *)
      _msg=(
        "Invalid argument '${arg}'."
      )
      _msg_error \
        "${_msg[*]}" \
        0
      _usage \
        1 ;;
  esac
done
shift \
  $((
    OPTIND - 1 \
  ))
if (( $# < 1 )); then
  target_command="build"
fi
if (( 0 < $# )); then
  target_command="${1}"
fi
shift \
  1 || \
  true
command_args+=(
  "$@"
)
_set_overrides
_show_config
app_opts=(
